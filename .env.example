# ============================================================================
# k8s-qa-rag-agent - Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in actual values. Never commit .env to git.
# ============================================================================

# ==== EXTERNAL SERVICES ====
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ==== EMBEDDINGS MODEL ====
# HuggingFace model identifier for embeddings
EMBEDDINGS_MODEL=BAAI/bge-base-en-v1.5
EMBEDDINGS_DEVICE=cpu

# ==== LLM API KEYS ====
# OpenAI or compatible API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ==== GITHUB WEBHOOK ====
# GitHub webhook secret (HMAC-SHA256 signing)
GITHUB_WEBHOOK_SECRET=
# List of GitHub repos to index (comma-separated)
GITHUB_REPOS=
# Private repo clone (indexer); optional for public repos and file:// fixtures
GITHUB_TOKEN=

# ==== INDEXER REPO ALLOWLIST (SEC-03) ====
# Empty = allow any github.com HTTPS remote. Set one or both to restrict.
INDEXER_ALLOWED_GITHUB_ORGS=
INDEXER_ALLOWED_REPO_URLS=
# file:// remotes (local dev / fixtures). Compose sets these on the indexer service.
INDEXER_ALLOW_FILE_REMOTES=
INDEXER_ALLOWED_FILE_PATH_PREFIXES=

# ==== SERVICES ====
INDEXER_PORT=8000
RETRIEVER_PORT=8001
QA_AGENT_PORT=8002
GIT_WATCHER_PORT=8003

# ==== OBSERVABILITY ====
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
LOG_LEVEL=INFO

# ==== CACHE ====
CACHE_TTL_SECONDS=600
