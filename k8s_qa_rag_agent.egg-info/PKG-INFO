```yaml
# k8s/base/indexer-cronjob.yaml
apiVersion: batch/v1
kind: CronJob
metadata:
  name: indexer-full-sync
spec:
  schedule: "0 * * * *"   # full re-index every hour
  concurrencyPolicy: Forbid
  jobTemplate:
    spec:
      template:
        spec:
          restartPolicy: OnFailure
          containers:
            - name: indexer
              image: your-registry/indexer:latest
              command: ["python", "-m", "indexer", "--full-sync"]
              env:
                - name: QDRANT_URL
                  value: "http://qdrant-svc:6333"
                - name: REPO_PATH
                  value: "/repos"
                - name: GIT_TOKEN
                  valueFrom:
                    secretKeyRef:
                      name: git-credentials
                      key: token
              volumeMounts:
                - name: repo-cache
                  mountPath: /repos
          volumes:
            - name: repo-cache
              persistentVolumeClaim:
                claimName: repo-cache-pvc
---
# Also expose the indexer as a Deployment for on-demand webhook triggers
apiVersion: apps/v1
kind: Deployment
metadata:
  name: indexer
spec:
  replicas: 1
  selector:
    matchLabels:
      app: indexer
  template:
    metadata:
      labels:
        app: indexer
    spec:
      containers:
        - name: indexer
          image: your-registry/indexer:latest
          command: ["uvicorn", "api:app", "--host", "0.0.0.0", "--port", "8080"]
          env:
            - name: QDRANT_URL
              value: "http://qdrant-svc:6333"
          resources:
            requests:
              cpu: "1"
              memory: "2Gi"   # embedding model in memory
            limits:
              cpu: "4"
              memory: "8Gi"
```

